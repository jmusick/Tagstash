# IMPORTANT: Copy this file to .env and update with your actual values

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tagstash
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT Secret (CHANGE THIS! Use a long random string)
JWT_SECRET=your_jwt_secret_change_this_in_production_use_random_string

# Optional: dedicated secret used to encrypt API keys at rest.
# If omitted, JWT_SECRET is used.
API_KEY_ENCRYPTION_SECRET=your_api_key_encryption_secret_change_this

# Server Configuration
PORT=5000
NODE_ENV=development
