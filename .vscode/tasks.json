{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Tagstash: dev",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev:all"
			],
			"isBackground": true,
			"group": "build",
			"problemMatcher": {
				"owner": "vite",
				"pattern": {
					"regexp": "^$"
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "VITE v",
					"endsPattern": "Local:"
				}
			}
		}
	]
}