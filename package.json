{
  "name": "tagstash",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A tag-based bookmarking web application",
  "scripts": {
    "dev": "vite",
    "server": "nodemon server/server.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run server\"",
    "setup:db": "node server/setup.js",
    "migrate": "node server/migrate.js",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.577.0",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.15.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^17.4.0",
    "nodemon": "^3.1.14",
    "vite": "^6.0.3"
  }
}
