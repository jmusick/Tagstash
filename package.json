{
  "name": "tagstash",
  "private": true,
  "version": "1.1.6",
  "type": "module",
  "description": "A tag-based bookmarking web application",
  "scripts": {
    "dev": "vite",
    "dev:api": "wrangler pages dev . --local --port 5000 --proxy 3000",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:api\"",
    "setup:db": "wrangler d1 migrations apply tagstash-db --local",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.2",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^6.12.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.15.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^17.4.0",
    "vite": "^6.0.3",
    "wrangler": "^4.11.1"
  }
}
